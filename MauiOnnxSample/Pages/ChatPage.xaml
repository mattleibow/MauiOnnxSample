<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiOnnxSample.Pages.ChatPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiOnnxSample.ViewModels"
    xmlns:models="clr-namespace:MauiOnnxSample.Models"
    Title="AI Chat"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A1A}">

    <!--
        NOTE: Styles for chat bubbles are applied in code-behind (ChatPage.xaml.cs)
        to avoid the ContentPage.Resources / Style Setter.Value pattern which can
        interact with MAUI 11 Preview on macOS 26 in unexpected ways.
    -->

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Status/loading banner: simple Label, no ActivityIndicator.
             ActivityIndicator.IsRunning binding crashes in libswiftObservation on MAUI 11
             Preview / macOS 26 (Swift Observation use-after-free during view graph update). -->
        <Label
            Grid.Row="0"
            Text="{Binding StatusMessage}"
            IsVisible="{Binding IsModelLoading}"
            BackgroundColor="{AppThemeBinding Light=#E5E5E5, Dark=#333333}"
            TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
            Padding="12,8"
            FontSize="13" />

        <!-- Chat message list.
             Uses ScrollView + VerticalStackLayout instead of CollectionView.
             CollectionView with x:DataType compiled bindings triggers a SIGSEGV in
             libswiftObservation.dylib on MAUI 11 Preview / Mac Catalyst (macOS 26).
             Messages are added programmatically from ChatPage.xaml.cs. -->
        <ScrollView
            Grid.Row="1"
            x:Name="MessagesScrollView"
            Margin="0,8,0,0">
            <VerticalStackLayout
                x:Name="MessagesContainer"
                Spacing="0"
                Padding="0,0,0,8" />
        </ScrollView>

        <!-- Input area -->
        <Border
            Grid.Row="2"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}"
            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#555555}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 0"
            Padding="12,8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">

                <!-- Text input -->
                <Border
                    Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#444444}"
                    Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#666666}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20"
                    Padding="14,8">
                    <Editor
                        x:Name="MessageInput"
                        Text="{Binding InputText}"
                        Placeholder="Ask me anything..."
                        PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                        BackgroundColor="Transparent"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="36"
                        MaximumHeightRequest="120"
                        Completed="OnEditorCompleted"
                        IsEnabled="{Binding IsModelLoading, Converter={StaticResource InvertedBoolConverter}}" />
                </Border>

                <!-- Stop button (visible when generating) -->
                <Button
                    Grid.Column="1"
                    Text="⏹"
                    Command="{Binding StopCommand}"
                    IsVisible="{Binding IsBusy}"
                    FontSize="18"
                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#555555}"
                    TextColor="{AppThemeBinding Light=#555555, Dark=White}"
                    CornerRadius="20"
                    WidthRequest="44"
                    HeightRequest="44"
                    Padding="0" />

                <!-- Send button -->
                <Button
                    Grid.Column="2"
                    Text="↑"
                    Command="{Binding SendCommand}"
                    IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    FontSize="20"
                    FontAttributes="Bold"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="22"
                    WidthRequest="44"
                    HeightRequest="44"
                    Padding="0" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>
